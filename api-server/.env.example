PORT=9000
CLIENT_URL=http://localhost:3000

# Upstash Redis (get from https://console.upstash.com)
REDIS_URL=rediss://default:xxxxx@xxx.upstash.io:6379

# Supabase (get from https://supabase.com/dashboard)
#   1. Create a project
#   2. Go to Project Settings → API
#   3. SUPABASE_URL = Project URL (e.g. https://xxxxx.supabase.co)
#   4. SUPABASE_SERVICE_KEY = service_role key (NOT the anon key)
#   5. Create a Storage bucket named "verse-outputs" and set it to Public
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...your_service_role_key
SUPABASE_BUCKET=verse-outputs

# Base URL where deployed sites are served (your Cloudflare Worker URL)
DEPLOY_BASE_URL=https://verse-proxy.your-subdomain.workers.dev
